{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "Backend - {{method}} {{route}}" },
        { "expr": "rate(ai_http_requests_total[1m])", "legendFormat": "AI Engine - {{method}} {{endpoint}}" }
      ]
    },
    {
      "title": "Latencia P95 (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "Backend P95" },
        { "expr": "histogram_quantile(0.95, rate(ai_http_request_duration_seconds_bucket[5m]))", "legendFormat": "AI Engine P95" }
      ]
    },
    {
      "title": "WebSocket Conexiones Activas",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        { "expr": "ws_active_connections", "legendFormat": "Backend WS" },
        { "expr": "ai_ws_active_connections", "legendFormat": "AI WS" }
      ]
    },
    {
      "title": "Robots Activos",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        { "expr": "ai_active_robots", "legendFormat": "Robots" }
      ]
    },
    {
      "title": "Salud del Sistema IA",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        { "expr": "ai_system_health", "legendFormat": "Health" }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 100, "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "yellow", "value": 50 },
          { "color": "green", "value": 80 }
        ]}}
      }
    },
    {
      "title": "CPU / Memoria AI Engine",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        { "expr": "ai_cpu_usage_percent", "legendFormat": "CPU %" },
        { "expr": "ai_memory_usage_percent", "legendFormat": "Mem %" }
      ]
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "rate(http_requests_total{status_code=~\"5..\"}[5m])", "legendFormat": "Backend 5xx" },
        { "expr": "rate(ai_http_requests_total{status_code=~\"5..\"}[5m])", "legendFormat": "AI 5xx" }
      ]
    },
    {
      "title": "MongoDB Operaciones",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "expr": "rate(mongodb_op_counters_total[5m])", "legendFormat": "{{type}}" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["ciudad-robot"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Ciudad Robot - Overview",
  "uid": "ciudad-robot-overview"
}

    "voice_commands": true,
    "gesture_recognition": true
  },
  "multiplayer": {
    "enabled": true,
    "voice_chat": true,
    "spatial_audio": true,
    "avatar_customization": true,
    "emotes": true
  },
  "scripting": {
    "language": "TypeScript",
    "sdk_version": "latest",
    "custom_components": true,
    "event_system": true
  },
  "analytics": {
    "visitor_tracking": true,

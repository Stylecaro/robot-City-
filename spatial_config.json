{
  "platform": "Spatial.io",
  "project_info": {
    "name": "Metaverso Professional",
    "description": "AI-driven virtual city with advanced robotics and autonomous systems",
    "category": "Experience",
    "visibility": "public",
    "featured": true
  },
  "space_settings": {
    "max_visitors": 50,
    "space_type": "custom",
    "environment": "outdoor_city",
    "time_of_day": "dynamic",
    "weather": "dynamic"
  },
